{
  "name": "blackwood",
  "version": "1.0.0",
  "description": "Blackwood daily notes — desktop wrapper",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --mac",
    "dist:all": "electron-builder --mac --linux --win"
  },
  "author": "Christian Weichel",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/csweichel/blackwood.git"
  },
  "devDependencies": {
    "electron": "^35.7.5",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "io.blackwood.desktop",
    "productName": "Blackwood",
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "build/icon.png"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "build/icon.png",
      "category": "Office"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.png"
    },
    "files": [
      "main.js",
      "preload.js",
      "settings.html",
      "config.js"
    ]
  }
}
