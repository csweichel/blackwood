{
  "manifest_version": 3,
  "name": "Blackwood Web Clipper",
  "version": "1.0.0",
  "description": "Clip web pages into Blackwood daily notes.",
  "permissions": ["activeTab", "storage", "contextMenus"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "commands": {
    "clip-page": {
      "suggested_key": {
        "default": "Alt+Shift+B"
      },
      "description": "Clip current page to Blackwood"
    }
  }
}
